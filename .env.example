AUTH_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
GEMINI_API_KEY=
# Vertex multimodal embeddings (image similarity Stage B).
# Set IMAGE_EMBEDDING_ENABLED=true to activate the embedding drainer in cron_dispatch.
IMAGE_EMBEDDING_ENABLED=false
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
# Service-account JSON (single line) used to mint access tokens at runtime.
GCP_SERVICE_ACCOUNT_KEY=
# Local-dev override only: static tokens expire after ~1h, do not use in production.
GCP_ACCESS_TOKEN=
# Wall-clock budget for the image-similarity cron drain (backfill + embeddings).
IMAGE_CRON_BUDGET_MS=20000
ADL_POSTGRES_URL=
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
# Temporary compatibility switch for providers returning a self-signed chain.
# Set to true only if TLS validation fails with SELF_SIGNED_CERT_IN_CHAIN.
POSTGRES_SSL_NO_VERIFY=false
DATA_STORE_DRIVER=postgres
DATA_READ_FALLBACK_EDGE=true
EDGE_CONFIG=
EDGE_CONFIG_ID=
VERCEL_API_TOKEN=
BLOB_READ_WRITE_TOKEN=
ADMIN_EMAIL=
ADMIN_PASSWORD=
MAX_SUBMISSION_IMAGE_BYTES=
CRON_SECRET=
# Shared bearer token for N8N automation workflows (POST /api/intake/leads)
AUTOMATION_SECRET=
SENTRY_DSN=
VITE_SENTRY_DSN=
FRAUD_VELOCITY_WINDOW_MINUTES=
FRAUD_USER_VELOCITY_FLAG=
FRAUD_USER_VELOCITY_BLOCK=
