AUTH_SECRET=
AUTH_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
GEMINI_API_KEY=
ADL_POSTGRES_URL=
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
# Temporary compatibility switch for providers returning a self-signed chain.
# Set to true only if TLS validation fails with SELF_SIGNED_CERT_IN_CHAIN.
POSTGRES_SSL_NO_VERIFY=false
DATA_STORE_DRIVER=postgres
DATA_READ_FALLBACK_EDGE=true
EDGE_CONFIG=
EDGE_CONFIG_ID=
VERCEL_API_TOKEN=
BLOB_READ_WRITE_TOKEN=
ADMIN_EMAIL=
ADMIN_PASSWORD=
MAX_SUBMISSION_IMAGE_BYTES=
CRON_SECRET=
# Shared bearer token for N8N automation workflows (POST /api/intake/leads)
AUTOMATION_SECRET=
SENTRY_DSN=
VITE_SENTRY_DSN=
FRAUD_VELOCITY_WINDOW_MINUTES=
FRAUD_USER_VELOCITY_FLAG=
FRAUD_USER_VELOCITY_BLOCK=
FRAUD_DEVICE_VELOCITY_FLAG=
FRAUD_IP_VELOCITY_FLAG=
FRAUD_TRAVEL_FLAG_KMH=
FRAUD_TRAVEL_BLOCK_KMH=
FRAUD_EXIF_TRUST_FLAG_THRESHOLD=
FRAUD_REVIEW_RISK_THRESHOLD=
QUEUE_MAX_ITEMS=
QUEUE_MAX_RETRY_COUNT=
QUEUE_MAX_ITEM_AGE_HOURS=
# Upstash Redis (optional) — global rate-limit store for consumeBucket.
# Unset = in-memory fallback (per-instance, AP). Set both to enable Redis.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
VITE_API_BASE=
VITE_ADMIN_EMAIL=
# Resend (auto-provisioned by Vercel Marketplace integration)
# Sending domain must be verified in Resend. Use the subdomain that's verified
# (e.g. app.africandatalayer.com), not the apex. Display-name format preferred
# for inbox rendering. Example:
#   RESEND_FROM="African Data Layer <noreply@app.africandatalayer.com>"
RESEND_API_KEY=
RESEND_FROM=
# Optional reply-to address. Helps deliverability and gives users a real
# inbox to write back to. Example: support@app.africandatalayer.com
RESEND_REPLY_TO=
# Public origin used to build links inside emails (e.g. https://adl.example.com)
APP_BASE_URL=
# Resend webhook signing secret (Svix-style, whsec_ prefix). Resend dashboard
# → Webhooks → reveal the signing secret. Preferred over the legacy shared-
# secret header. Verifies svix-id + svix-timestamp + raw body signature.
RESEND_WEBHOOK_SIGNING_SECRET=
# Legacy fallback shared secret. Used only when RESEND_WEBHOOK_SIGNING_SECRET
# is unset. Will be removed once Svix verify proven in prod.
RESEND_WEBHOOK_SECRET=
# Cap recipients per campaign send (synchronous fan-out within function timeout)
EMAIL_CAMPAIGN_MAX_RECIPIENTS=5000
# Per-tick cron drain budget for email campaigns (recipients per minute)
EMAIL_DRAIN_BATCH_SIZE=50
# Africa's Talking SMS provider
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=
AT_USE_SANDBOX=false
AT_INBOUND_SECRET=
SMS_CAMPAIGN_MAX_RECIPIENTS=1000
# Per-tick cron drain budget for SMS campaigns (recipients per minute)
SMS_DRAIN_BATCH_SIZE=50
# Max campaigns drained per cron tick (across email + SMS)
CAMPAIGN_DRAIN_MAX_CAMPAIGNS=5
