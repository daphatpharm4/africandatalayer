{
  "framework": "vite",
  "buildCommand": "npm run build",
  "devCommand": "vite",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/analytics?view=cron_dispatch",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/analytics?view=campaign_drain",
      "schedule": "0 7 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(self), geolocation=(self), microphone=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob: https://*.public.blob.vercel-storage.com https://*.tile.openstreetmap.org https://*.basemaps.cartocdn.com https://picsum.photos; connect-src 'self' https://africandatalayer.vercel.app https://*.ingest.sentry.io https://oauth2.googleapis.com https://accounts.google.com https://appleid.apple.com; form-action 'self' https://accounts.google.com https://appleid.apple.com; frame-ancestors 'none';"
        }
      ]
    },
    {
      "source": "/api/auth/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, X-Idempotency-Key, X-Capacitor-Platform" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    },
    {
      "source": "/api/submissions/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, PATCH, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, X-Idempotency-Key" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    },
    {
      "source": "/api/user",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, PUT, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, X-Idempotency-Key" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    },
    {
      "source": "/api/analytics",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    },
    {
      "source": "/api/leaderboard",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    },
    {
      "source": "/api/health",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    },
    {
      "source": "/api/ai/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    },
    {
      "source": "/api/intake/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    },
    {
      "source": "/api/privacy",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" },
        { "key": "Access-Control-Max-Age", "value": "86400" }
      ]
    },
    {
      "source": "/api/cron/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/api/submissions",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/api/analytics",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=300, stale-while-revalidate=600" }
      ]
    },
    {
      "source": "/api/health",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store" }
      ]
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/auth/csrf", "destination": "/api/auth/[...auth]" },
    { "source": "/api/auth/session", "destination": "/api/auth/[...auth]" },
    { "source": "/api/auth/signin", "destination": "/api/auth/[...auth]" },
    { "source": "/api/auth/callback/:path*", "destination": "/api/auth/[...auth]" },
    { "source": "/api/auth/signin/:path*", "destination": "/api/auth/[...auth]" },
    { "source": "/api/auth/signout", "destination": "/api/auth/[...auth]" },
    { "source": "/api/auth/providers", "destination": "/api/auth/[...auth]" },
    { "source": "/api/auth/error", "destination": "/api/auth/[...auth]" },
    { "source": "/api/auth/verify-request", "destination": "/api/auth/[...auth]" },
    { "source": "/api/intake/leads/:id", "destination": "/api/intake/leads" },
    { "source": "/api/ai/extract-submission", "destination": "/api/ai/search?view=extract-submission" },
    { "source": "/api/ai/review-summary", "destination": "/api/ai/search?view=review-summary" },
    { "source": "/api/ai/analytics-query", "destination": "/api/ai/search?view=analytics-query" },
    { "source": "/api/ai/report-draft", "destination": "/api/ai/search?view=report-draft" },
    { "source": "/api/poi/import/osm", "destination": "/api/intake/leads?view=poi-import-osm" },
    { "source": "/api/poi/candidates/:id/assign", "destination": "/api/intake/leads?view=poi-assign&id=:id" },
    { "source": "/api/poi/candidates/:id/promote", "destination": "/api/intake/leads?view=poi-promote&id=:id" },
    { "source": "/api/poi/candidates/:id", "destination": "/api/intake/leads?view=poi-candidate&id=:id" },
    { "source": "/api/poi/candidates", "destination": "/api/intake/leads?view=poi-candidates" },
    { "source": "/api/comms/unsubscribe", "destination": "/api/privacy?view=unsubscribe" },
    { "source": "/api/comms/email/webhook", "destination": "/api/privacy?view=email-webhook" },
    { "source": "/api/comms/sms/inbound", "destination": "/api/privacy?view=sms-inbound" },
    { "source": "/api/comms/sms/dlr", "destination": "/api/privacy?view=sms-dlr" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
