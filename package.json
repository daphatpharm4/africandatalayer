{
  "name": "african-data-layer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run check:function-budget && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "node --import tsx --test tests/*.test.ts",
    "test:publisher": "node --test .claude/skills/social-publisher-skill/tests/*.test.mjs",
    "test:e2e": "playwright test e2e/smoke",
    "test:e2e:docs": "PW_DOCS=1 playwright test e2e/docs && npm run docs:media:sync",
    "test:e2e:headed": "playwright test e2e/smoke --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update": "playwright test --update-snapshots",
    "docs:media:sync": "node scripts/sync-docs-media.mjs",
    "playwright:install": "playwright install chromium",
    "test:ci": "npm run lint && npm run typecheck && npm run test && npm run build",
    "check:function-budget": "node scripts/check-vercel-function-budget.mjs",
    "typecheck": "tsc --noEmit",
    "migrate": "node scripts/migrate.mjs",
    "migrate:dry": "node scripts/migrate.mjs --dry-run",
    "backup:postgres": "node scripts/backup-postgres-to-blob.mjs",
    "seed:submissions": "node scripts/seed-edge-submissions.mjs",
    "import:bonamoussadi": "node scripts/import-bonamoussadi-csv.mjs",
    "migrate:edge-to-postgres": "node scripts/migrate-edge-config-to-postgres.mjs",
    "backfill:exif": "node scripts/backfill-fraud-exif.mjs",
    "cap:sync": "npm run build && npx cap sync",
    "cap:sync:ios": "npm run build && npx cap sync ios",
    "cap:sync:android": "npm run build && npx cap sync android",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android"
  },
  "dependencies": {
    "@auth/core": "^0.33.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.1.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.3",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@google/genai": "1.3.0",
    "@sentry/browser": "^10.42.0",
    "@sentry/node": "^10.42.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/blob": "^2.0.1",
    "@vercel/edge-config": "^1.4.0",
    "@vercel/speed-insights": "^1.3.1",
    "bcryptjs": "^2.4.3",
    "exifr": "^7.1.3",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "lucide-react": "0.475.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "recharts": "2.15.0",
    "rollup": "^4.60.1",
    "sharp": "^0.33.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.19.7",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "nock": "^14.0.15",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.2.0"
  }
}
