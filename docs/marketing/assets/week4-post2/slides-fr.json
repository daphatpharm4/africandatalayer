  {
    "id": "01-fr",
    "html": "<!doctype html><html><head><meta charset='utf-8'><link rel='preconnect' href='https://fonts.googleapis.com'><link rel='preconnect' href='https://fonts.gstatic.com' crossorigin><link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap' rel='stylesheet'><style>\nhtml,body{margin:0;padding:0;width:1080px;height:1350px;overflow:hidden;font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}\n*{box-sizing:border-box}\n.stamp{position:absolute;top:56px;right:56px;padding:14px 24px;border-radius:999px;background:#f4c317;border:2px solid #0f2b46;color:#0f2b46;font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;z-index:2}\n.micro{font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;padding:10px 20px;border-radius:999px;display:inline-block;align-self:flex-start}\n.accent-bar{height:6px;width:96px;border-radius:3px;margin:20px 0}\n.page-num{position:absolute;bottom:56px;right:72px;font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;opacity:0.55}\n.ghost{position:absolute;font-weight:700;font-size:340px;line-height:0.85;letter-spacing:-0.04em;opacity:0.08;top:80px;right:90px;z-index:0}\nbody{background:#0f2b46;color:#f2f6fa;padding:80px;display:flex;flex-direction:column;position:relative}</style></head><body>\n    <div class='stamp'>Lancement · Semaine 4</div>\n    <div class='micro' style='background:rgba(244,195,23,0.14);color:#f4c317'>Donnee De Terrain · Anatomie</div>\n    <div style='display:flex;align-items:center;gap:48px;margin-top:72px'>\n      <div style='font-weight:700;font-size:240px;line-height:0.85;letter-spacing:-0.04em;color:#c86b4a'>5</div>\n      <div style='display:flex;flex-direction:column;gap:14px'>\n        <div style='font-weight:700;font-size:22pt;letter-spacing:0.12em;text-transform:uppercase;color:rgba(242,246,250,0.75)'>Portes<br/>Par Point</div>\n        <div style='width:64px;height:4px;background:#f4c317;border-radius:2px'></div>\n        <div style='font-weight:500;font-size:18pt;color:rgba(242,246,250,0.7)'>Chaine de verification</div>\n      </div>\n    </div>\n    <div style='margin-top:96px'>\n      <div style='font-weight:700;font-size:74px;line-height:1.02;letter-spacing:-0.015em'>Ce que « verifie »<br/>veut vraiment dire.</div>\n      <div style='font-weight:500;font-size:26pt;line-height:1.35;color:rgba(242,246,250,0.72);margin-top:28px;max-width:880px'>Six diapositives. Cinq portes. Chaque soumission sur la carte les a toutes passees.</div>\n    </div>\n    <div style='margin-top:auto;display:flex;align-items:center;gap:18px;font-weight:500;font-size:20pt;color:rgba(242,246,250,0.65)'>\n      <div style='width:32px;height:2px;background:#c86b4a'></div>\n      Glissez →\n    </div>\n  </body></html>"
  },
  {
    "id": "02-fr",
    "html": "<!doctype html><html><head><meta charset='utf-8'><link rel='preconnect' href='https://fonts.googleapis.com'><link rel='preconnect' href='https://fonts.gstatic.com' crossorigin><link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap' rel='stylesheet'><style>\nhtml,body{margin:0;padding:0;width:1080px;height:1350px;overflow:hidden;font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}\n*{box-sizing:border-box}\n.stamp{position:absolute;top:56px;right:56px;padding:14px 24px;border-radius:999px;background:#f4c317;border:2px solid #0f2b46;color:#0f2b46;font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;z-index:2}\n.micro{font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;padding:10px 20px;border-radius:999px;display:inline-block;align-self:flex-start}\n.accent-bar{height:6px;width:96px;border-radius:3px;margin:20px 0}\n.page-num{position:absolute;bottom:56px;right:72px;font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;opacity:0.55}\n.ghost{position:absolute;font-weight:700;font-size:340px;line-height:0.85;letter-spacing:-0.04em;opacity:0.08;top:80px;right:90px;z-index:0}\nbody{background:#f2f6fa;color:#0f2b46;padding:80px;display:flex;flex-direction:column;position:relative}</style></head><body>\n      <div class='stamp'>Lancement · Semaine 4</div>\n      <div class='ghost' style='color:#c86b4a'>1</div>\n      <div class='micro' style='background:rgba(200,107,74,0.14);color:#c86b4a'>Porte 1 · Verrouillage GPS</div>\n      <div class='accent-bar' style='background:#c86b4a'></div>\n      <div style='font-weight:700;font-size:54px;line-height:1.04;letter-spacing:-0.01em;margin-top:8px;position:relative;z-index:1'>Coordonnees prises<br/>a la source.</div>\n      <div style='font-weight:500;font-size:24pt;line-height:1.35;color:rgba(15,43,70,0.78);margin-top:24px;max-width:920px;position:relative;z-index:1'>Vitesse et distance comparees au dernier point de l'agent. Les sauts impossibles sont signales avant l'enregistrement.</div>\n      <div style='margin-top:auto;font-weight:500;font-style:italic;font-size:22pt;color:rgba(15,43,70,0.65);position:relative;z-index:1'>« Les teleporteurs sont attrapes ici. »</div>\n      <div class='page-num' style='color:#0f2b46'>02 / 06</div>\n    </body></html>"
  },
  {
    "id": "03-fr",
    "html": "<!doctype html><html><head><meta charset='utf-8'><link rel='preconnect' href='https://fonts.googleapis.com'><link rel='preconnect' href='https://fonts.gstatic.com' crossorigin><link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap' rel='stylesheet'><style>\nhtml,body{margin:0;padding:0;width:1080px;height:1350px;overflow:hidden;font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}\n*{box-sizing:border-box}\n.stamp{position:absolute;top:56px;right:56px;padding:14px 24px;border-radius:999px;background:#f4c317;border:2px solid #0f2b46;color:#0f2b46;font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;z-index:2}\n.micro{font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;padding:10px 20px;border-radius:999px;display:inline-block;align-self:flex-start}\n.accent-bar{height:6px;width:96px;border-radius:3px;margin:20px 0}\n.page-num{position:absolute;bottom:56px;right:72px;font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;opacity:0.55}\n.ghost{position:absolute;font-weight:700;font-size:340px;line-height:0.85;letter-spacing:-0.04em;opacity:0.08;top:80px;right:90px;z-index:0}\nbody{background:#eaf1ec;color:#0f2b46;padding:80px;display:flex;flex-direction:column;position:relative}</style></head><body>\n      <div class='stamp'>Lancement · Semaine 4</div>\n      <div class='ghost' style='color:#4c7c59'>2</div>\n      <div class='micro' style='background:rgba(76,124,89,0.18);color:#2f5438'>Porte 2 · Photo + EXIF</div>\n      <div class='accent-bar' style='background:#4c7c59'></div>\n      <div style='font-weight:700;font-size:54px;line-height:1.04;letter-spacing:-0.01em;margin-top:8px;position:relative;z-index:1'>Lire les metadonnees<br/>avant la photo.</div>\n      <div style='font-weight:500;font-size:24pt;line-height:1.35;color:rgba(15,43,70,0.78);margin-top:24px;max-width:920px;position:relative;z-index:1'>L'image arrive avec horodatage, empreinte d'appareil et metadonnees de capture. Les photos recyclees ne correspondent pas. Elles ne passent pas.</div>\n      <div style='margin-top:auto;font-weight:500;font-style:italic;font-size:22pt;color:rgba(15,43,70,0.65);position:relative;z-index:1'>« Les photos recyclees ne passent pas. »</div>\n      <div class='page-num' style='color:#0f2b46'>03 / 06</div>\n    </body></html>"
  },
  {
    "id": "04-fr",
    "html": "<!doctype html><html><head><meta charset='utf-8'><link rel='preconnect' href='https://fonts.googleapis.com'><link rel='preconnect' href='https://fonts.gstatic.com' crossorigin><link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap' rel='stylesheet'><style>\nhtml,body{margin:0;padding:0;width:1080px;height:1350px;overflow:hidden;font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}\n*{box-sizing:border-box}\n.stamp{position:absolute;top:56px;right:56px;padding:14px 24px;border-radius:999px;background:#f4c317;border:2px solid #0f2b46;color:#0f2b46;font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;z-index:2}\n.micro{font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;padding:10px 20px;border-radius:999px;display:inline-block;align-self:flex-start}\n.accent-bar{height:6px;width:96px;border-radius:3px;margin:20px 0}\n.page-num{position:absolute;bottom:56px;right:72px;font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;opacity:0.55}\n.ghost{position:absolute;font-weight:700;font-size:340px;line-height:0.85;letter-spacing:-0.04em;opacity:0.08;top:80px;right:90px;z-index:0}\nbody{background:#f2f6fa;color:#0f2b46;padding:80px;display:flex;flex-direction:column;position:relative}</style></head><body>\n      <div class='stamp'>Lancement · Semaine 4</div>\n      <div class='ghost' style='color:#f4c317'>3</div>\n      <div class='micro' style='background:rgba(244,195,23,0.28);color:#0f2b46'>Porte 3 · Doublons</div>\n      <div class='accent-bar' style='background:#f4c317'></div>\n      <div style='font-weight:700;font-size:54px;line-height:1.04;letter-spacing:-0.01em;margin-top:8px;position:relative;z-index:1'>Meme endroit, meme jour,<br/>meme telephone ?</div>\n      <div style='font-weight:500;font-size:24pt;line-height:1.35;color:rgba(15,43,70,0.78);margin-top:24px;max-width:920px;position:relative;z-index:1'>La plateforme pose la question avant d'accepter. Les amas de doublons vont en revue plutot que gonfler le jeu de donnees.</div>\n      <div style='margin-top:auto;font-weight:500;font-style:italic;font-size:22pt;color:rgba(15,43,70,0.65);position:relative;z-index:1'>« Un vrai point vaut mieux que cinq doublons. »</div>\n      <div class='page-num' style='color:#0f2b46'>04 / 06</div>\n    </body></html>"
  },
  {
    "id": "05-fr",
    "html": "<!doctype html><html><head><meta charset='utf-8'><link rel='preconnect' href='https://fonts.googleapis.com'><link rel='preconnect' href='https://fonts.gstatic.com' crossorigin><link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap' rel='stylesheet'><style>\nhtml,body{margin:0;padding:0;width:1080px;height:1350px;overflow:hidden;font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}\n*{box-sizing:border-box}\n.stamp{position:absolute;top:56px;right:56px;padding:14px 24px;border-radius:999px;background:#f4c317;border:2px solid #0f2b46;color:#0f2b46;font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;z-index:2}\n.micro{font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;padding:10px 20px;border-radius:999px;display:inline-block;align-self:flex-start}\n.accent-bar{height:6px;width:96px;border-radius:3px;margin:20px 0}\n.page-num{position:absolute;bottom:56px;right:72px;font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;opacity:0.55}\n.ghost{position:absolute;font-weight:700;font-size:340px;line-height:0.85;letter-spacing:-0.04em;opacity:0.08;top:80px;right:90px;z-index:0}\nbody{background:#fff8f4;color:#0f2b46;padding:80px;display:flex;flex-direction:column;position:relative}</style></head><body>\n      <div class='stamp'>Lancement · Semaine 4</div>\n      <div class='ghost' style='color:#c86b4a'>4</div>\n      <div class='micro' style='background:rgba(200,107,74,0.18);color:#c86b4a'>Porte 4 · Score De Risque</div>\n      <div class='accent-bar' style='background:#c86b4a'></div>\n      <div style='font-weight:700;font-size:54px;line-height:1.04;letter-spacing:-0.01em;margin-top:8px;position:relative;z-index:1'>Chaque soumission recoit<br/>une lecture numerique.</div>\n      <div style='font-weight:500;font-size:24pt;line-height:1.35;color:rgba(15,43,70,0.78);margin-top:24px;max-width:920px;position:relative;z-index:1'>Risque faible : ca passe. Risque eleve : revue admin. Les schemas suspects remontent — ils ne se faufilent pas.</div>\n      <div style='margin-top:auto;font-weight:500;font-style:italic;font-size:22pt;color:rgba(15,43,70,0.65);position:relative;z-index:1'>« Les schemas suspects remontent. »</div>\n      <div class='page-num' style='color:#0f2b46'>05 / 06</div>\n    </body></html>"
  },
  {
    "id": "06-fr",
    "html": "<!doctype html><html><head><meta charset='utf-8'><link rel='preconnect' href='https://fonts.googleapis.com'><link rel='preconnect' href='https://fonts.gstatic.com' crossorigin><link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap' rel='stylesheet'><style>\nhtml,body{margin:0;padding:0;width:1080px;height:1350px;overflow:hidden;font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}\n*{box-sizing:border-box}\n.stamp{position:absolute;top:56px;right:56px;padding:14px 24px;border-radius:999px;background:#f4c317;border:2px solid #0f2b46;color:#0f2b46;font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;z-index:2}\n.micro{font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;padding:10px 20px;border-radius:999px;display:inline-block;align-self:flex-start}\n.accent-bar{height:6px;width:96px;border-radius:3px;margin:20px 0}\n.page-num{position:absolute;bottom:56px;right:72px;font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;opacity:0.55}\n.ghost{position:absolute;font-weight:700;font-size:340px;line-height:0.85;letter-spacing:-0.04em;opacity:0.08;top:80px;right:90px;z-index:0}\nbody{background:#c86b4a;color:#0f2b46;padding:80px;display:flex;flex-direction:column;position:relative}</style></head><body>\n    <div class='stamp'>Lancement · Semaine 4</div>\n    <div class='ghost' style='color:rgba(15,43,70,0.08)'>5</div>\n    <div class='micro' style='background:rgba(244,195,23,0.35);color:#0f2b46'>Porte 5 · Niveau De Confiance</div>\n    <div style='margin-top:32px;position:relative;z-index:1'>\n      <div style='font-weight:700;font-size:58px;line-height:1.02;letter-spacing:-0.015em'>Les agents de niveau<br/>eleve gagnent plus de<br/>poids sur le jeu de donnees.</div>\n      <div style='font-weight:500;font-size:24pt;line-height:1.35;margin-top:24px;color:rgba(15,43,70,0.82);max-width:900px'>Parce qu'ils l'ont merite. Le point arrive sur la carte uniquement apres les cinq portes.</div>\n    </div>\n    <div style='margin-top:32px;display:flex;gap:14px;flex-wrap:wrap;position:relative;z-index:1'>\n      <div style='padding:14px 22px;border-radius:14px;background:rgba(15,43,70,0.12);font-weight:700;font-size:16pt'>Bronze</div>\n      <div style='padding:14px 22px;border-radius:14px;background:rgba(15,43,70,0.18);font-weight:700;font-size:16pt'>Argent</div>\n      <div style='padding:14px 22px;border-radius:14px;background:#0f2b46;color:#f4c317;font-weight:700;font-size:16pt'>Or</div>\n    </div>\n    <div style='margin-top:auto;display:flex;flex-direction:column;gap:16px;position:relative;z-index:1'>\n      <div style='align-self:flex-start;padding:22px 34px;border-radius:999px;background:#0f2b46;color:#f2f6fa;font-weight:700;font-size:20pt;display:flex;align-items:center;gap:14px'>\n        <span>Telecharger · DM « CARTE »</span>\n        <span style='color:#f4c317'>→</span>\n      </div>\n      <div style='font-weight:500;font-size:19pt;color:rgba(15,43,70,0.72)'>Voila ce que veut dire donnee de terrain.</div>\n    </div>\n  </body></html>"
  }
