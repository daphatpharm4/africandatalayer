  {
    "id": "01",
    "html": "<!doctype html><html><head><meta charset='utf-8'><link rel='preconnect' href='https://fonts.googleapis.com'><link rel='preconnect' href='https://fonts.gstatic.com' crossorigin><link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap' rel='stylesheet'><style>\nhtml,body{margin:0;padding:0;width:1080px;height:1350px;overflow:hidden;font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}\n*{box-sizing:border-box}\n.stamp{position:absolute;top:56px;right:56px;padding:14px 24px;border-radius:999px;background:#f4c317;border:2px solid #0f2b46;color:#0f2b46;font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;z-index:2}\n.micro{font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;padding:10px 20px;border-radius:999px;display:inline-block;align-self:flex-start}\n.accent-bar{height:6px;width:96px;border-radius:3px;margin:20px 0}\n.page-num{position:absolute;bottom:56px;right:72px;font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;opacity:0.55}\n.ghost{position:absolute;font-weight:700;font-size:340px;line-height:0.85;letter-spacing:-0.04em;opacity:0.08;top:80px;right:90px;z-index:0}\nbody{background:#0f2b46;color:#f2f6fa;padding:80px;display:flex;flex-direction:column;position:relative}</style></head><body>\n    <div class='stamp'>Launch · Week 4</div>\n    <div class='micro' style='background:rgba(244,195,23,0.14);color:#f4c317'>Ground Truth · Anatomy</div>\n    <div style='display:flex;align-items:center;gap:48px;margin-top:72px'>\n      <div style='font-weight:700;font-size:240px;line-height:0.85;letter-spacing:-0.04em;color:#c86b4a'>5</div>\n      <div style='display:flex;flex-direction:column;gap:14px'>\n        <div style='font-weight:700;font-size:22pt;letter-spacing:0.12em;text-transform:uppercase;color:rgba(242,246,250,0.75)'>Gates<br/>Per Point</div>\n        <div style='width:64px;height:4px;background:#f4c317;border-radius:2px'></div>\n        <div style='font-weight:500;font-size:18pt;color:rgba(242,246,250,0.7)'>Verification chain</div>\n      </div>\n    </div>\n    <div style='margin-top:96px'>\n      <div style='font-weight:700;font-size:80px;line-height:1.02;letter-spacing:-0.015em'>What \"verified\"<br/>actually means.</div>\n      <div style='font-weight:500;font-size:26pt;line-height:1.35;color:rgba(242,246,250,0.72);margin-top:28px;max-width:880px'>Six slides. Five gates. Every submission you see on the map crossed all of them.</div>\n    </div>\n    <div style='margin-top:auto;display:flex;align-items:center;gap:18px;font-weight:500;font-size:20pt;color:rgba(242,246,250,0.65)'>\n      <div style='width:32px;height:2px;background:#c86b4a'></div>\n      Swipe →\n    </div>\n  </body></html>"
  },
  {
    "id": "02",
    "html": "<!doctype html><html><head><meta charset='utf-8'><link rel='preconnect' href='https://fonts.googleapis.com'><link rel='preconnect' href='https://fonts.gstatic.com' crossorigin><link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap' rel='stylesheet'><style>\nhtml,body{margin:0;padding:0;width:1080px;height:1350px;overflow:hidden;font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}\n*{box-sizing:border-box}\n.stamp{position:absolute;top:56px;right:56px;padding:14px 24px;border-radius:999px;background:#f4c317;border:2px solid #0f2b46;color:#0f2b46;font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;z-index:2}\n.micro{font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;padding:10px 20px;border-radius:999px;display:inline-block;align-self:flex-start}\n.accent-bar{height:6px;width:96px;border-radius:3px;margin:20px 0}\n.page-num{position:absolute;bottom:56px;right:72px;font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;opacity:0.55}\n.ghost{position:absolute;font-weight:700;font-size:340px;line-height:0.85;letter-spacing:-0.04em;opacity:0.08;top:80px;right:90px;z-index:0}\nbody{background:#f2f6fa;color:#0f2b46;padding:80px;display:flex;flex-direction:column;position:relative}</style></head><body>\n      <div class='stamp'>Launch · Week 4</div>\n      <div class='ghost' style='color:#c86b4a'>1</div>\n      <div class='micro' style='background:rgba(200,107,74,0.14);color:#c86b4a'>Gate 1 · GPS Lock</div>\n      <div class='accent-bar' style='background:#c86b4a'></div>\n      <div style='font-weight:700;font-size:60px;line-height:1.04;letter-spacing:-0.01em;margin-top:8px;position:relative;z-index:1'>Coordinates captured<br/>at the source.</div>\n      <div style='font-weight:500;font-size:24pt;line-height:1.35;color:rgba(15,43,70,0.78);margin-top:24px;max-width:920px;position:relative;z-index:1'>Velocity and travel distance checked against the agent's last point. Impossible jumps get flagged before the data lands.</div>\n      <div style='margin-top:auto;font-weight:500;font-style:italic;font-size:22pt;color:rgba(15,43,70,0.65);position:relative;z-index:1'>\"Teleporters get caught here.\"</div>\n      <div class='page-num' style='color:#0f2b46'>02 / 06</div>\n    </body></html>"
  },
  {
    "id": "03",
    "html": "<!doctype html><html><head><meta charset='utf-8'><link rel='preconnect' href='https://fonts.googleapis.com'><link rel='preconnect' href='https://fonts.gstatic.com' crossorigin><link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap' rel='stylesheet'><style>\nhtml,body{margin:0;padding:0;width:1080px;height:1350px;overflow:hidden;font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}\n*{box-sizing:border-box}\n.stamp{position:absolute;top:56px;right:56px;padding:14px 24px;border-radius:999px;background:#f4c317;border:2px solid #0f2b46;color:#0f2b46;font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;z-index:2}\n.micro{font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;padding:10px 20px;border-radius:999px;display:inline-block;align-self:flex-start}\n.accent-bar{height:6px;width:96px;border-radius:3px;margin:20px 0}\n.page-num{position:absolute;bottom:56px;right:72px;font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;opacity:0.55}\n.ghost{position:absolute;font-weight:700;font-size:340px;line-height:0.85;letter-spacing:-0.04em;opacity:0.08;top:80px;right:90px;z-index:0}\nbody{background:#eaf1ec;color:#0f2b46;padding:80px;display:flex;flex-direction:column;position:relative}</style></head><body>\n      <div class='stamp'>Launch · Week 4</div>\n      <div class='ghost' style='color:#4c7c59'>2</div>\n      <div class='micro' style='background:rgba(76,124,89,0.18);color:#2f5438'>Gate 2 · Photo + EXIF</div>\n      <div class='accent-bar' style='background:#4c7c59'></div>\n      <div style='font-weight:700;font-size:60px;line-height:1.04;letter-spacing:-0.01em;margin-top:8px;position:relative;z-index:1'>Read the metadata<br/>before trusting the picture.</div>\n      <div style='font-weight:500;font-size:24pt;line-height:1.35;color:rgba(15,43,70,0.78);margin-top:24px;max-width:920px;position:relative;z-index:1'>Image lands with timestamp, device fingerprint, and capture metadata. Recycled photos do not match. They do not pass.</div>\n      <div style='margin-top:auto;font-weight:500;font-style:italic;font-size:22pt;color:rgba(15,43,70,0.65);position:relative;z-index:1'>\"Recycled photos do not pass.\"</div>\n      <div class='page-num' style='color:#0f2b46'>03 / 06</div>\n    </body></html>"
  },
  {
    "id": "04",
    "html": "<!doctype html><html><head><meta charset='utf-8'><link rel='preconnect' href='https://fonts.googleapis.com'><link rel='preconnect' href='https://fonts.gstatic.com' crossorigin><link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap' rel='stylesheet'><style>\nhtml,body{margin:0;padding:0;width:1080px;height:1350px;overflow:hidden;font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}\n*{box-sizing:border-box}\n.stamp{position:absolute;top:56px;right:56px;padding:14px 24px;border-radius:999px;background:#f4c317;border:2px solid #0f2b46;color:#0f2b46;font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;z-index:2}\n.micro{font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;padding:10px 20px;border-radius:999px;display:inline-block;align-self:flex-start}\n.accent-bar{height:6px;width:96px;border-radius:3px;margin:20px 0}\n.page-num{position:absolute;bottom:56px;right:72px;font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;opacity:0.55}\n.ghost{position:absolute;font-weight:700;font-size:340px;line-height:0.85;letter-spacing:-0.04em;opacity:0.08;top:80px;right:90px;z-index:0}\nbody{background:#f2f6fa;color:#0f2b46;padding:80px;display:flex;flex-direction:column;position:relative}</style></head><body>\n      <div class='stamp'>Launch · Week 4</div>\n      <div class='ghost' style='color:#f4c317'>3</div>\n      <div class='micro' style='background:rgba(244,195,23,0.28);color:#0f2b46'>Gate 3 · Duplicate Check</div>\n      <div class='accent-bar' style='background:#f4c317'></div>\n      <div style='font-weight:700;font-size:60px;line-height:1.04;letter-spacing:-0.01em;margin-top:8px;position:relative;z-index:1'>Same place, same day,<br/>same phone?</div>\n      <div style='font-weight:500;font-size:24pt;line-height:1.35;color:rgba(15,43,70,0.78);margin-top:24px;max-width:920px;position:relative;z-index:1'>The platform asks before it accepts. Duplicate clusters route to review instead of inflating the dataset.</div>\n      <div style='margin-top:auto;font-weight:500;font-style:italic;font-size:22pt;color:rgba(15,43,70,0.65);position:relative;z-index:1'>\"One real point beats five duplicates.\"</div>\n      <div class='page-num' style='color:#0f2b46'>04 / 06</div>\n    </body></html>"
  },
  {
    "id": "05",
    "html": "<!doctype html><html><head><meta charset='utf-8'><link rel='preconnect' href='https://fonts.googleapis.com'><link rel='preconnect' href='https://fonts.gstatic.com' crossorigin><link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap' rel='stylesheet'><style>\nhtml,body{margin:0;padding:0;width:1080px;height:1350px;overflow:hidden;font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}\n*{box-sizing:border-box}\n.stamp{position:absolute;top:56px;right:56px;padding:14px 24px;border-radius:999px;background:#f4c317;border:2px solid #0f2b46;color:#0f2b46;font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;z-index:2}\n.micro{font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;padding:10px 20px;border-radius:999px;display:inline-block;align-self:flex-start}\n.accent-bar{height:6px;width:96px;border-radius:3px;margin:20px 0}\n.page-num{position:absolute;bottom:56px;right:72px;font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;opacity:0.55}\n.ghost{position:absolute;font-weight:700;font-size:340px;line-height:0.85;letter-spacing:-0.04em;opacity:0.08;top:80px;right:90px;z-index:0}\nbody{background:#fff8f4;color:#0f2b46;padding:80px;display:flex;flex-direction:column;position:relative}</style></head><body>\n      <div class='stamp'>Launch · Week 4</div>\n      <div class='ghost' style='color:#c86b4a'>4</div>\n      <div class='micro' style='background:rgba(200,107,74,0.18);color:#c86b4a'>Gate 4 · Risk Score</div>\n      <div class='accent-bar' style='background:#c86b4a'></div>\n      <div style='font-weight:700;font-size:60px;line-height:1.04;letter-spacing:-0.01em;margin-top:8px;position:relative;z-index:1'>Every submission gets<br/>a numeric risk read.</div>\n      <div style='font-weight:500;font-size:24pt;line-height:1.35;color:rgba(15,43,70,0.78);margin-top:24px;max-width:920px;position:relative;z-index:1'>Low risk goes through. Higher risk routes to admin review. Suspicious patterns surface — they do not slip through.</div>\n      <div style='margin-top:auto;font-weight:500;font-style:italic;font-size:22pt;color:rgba(15,43,70,0.65);position:relative;z-index:1'>\"Suspicious patterns surface, not slip through.\"</div>\n      <div class='page-num' style='color:#0f2b46'>05 / 06</div>\n    </body></html>"
  },
  {
    "id": "06",
    "html": "<!doctype html><html><head><meta charset='utf-8'><link rel='preconnect' href='https://fonts.googleapis.com'><link rel='preconnect' href='https://fonts.gstatic.com' crossorigin><link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap' rel='stylesheet'><style>\nhtml,body{margin:0;padding:0;width:1080px;height:1350px;overflow:hidden;font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}\n*{box-sizing:border-box}\n.stamp{position:absolute;top:56px;right:56px;padding:14px 24px;border-radius:999px;background:#f4c317;border:2px solid #0f2b46;color:#0f2b46;font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;z-index:2}\n.micro{font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;padding:10px 20px;border-radius:999px;display:inline-block;align-self:flex-start}\n.accent-bar{height:6px;width:96px;border-radius:3px;margin:20px 0}\n.page-num{position:absolute;bottom:56px;right:72px;font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;opacity:0.55}\n.ghost{position:absolute;font-weight:700;font-size:340px;line-height:0.85;letter-spacing:-0.04em;opacity:0.08;top:80px;right:90px;z-index:0}\nbody{background:#c86b4a;color:#0f2b46;padding:80px;display:flex;flex-direction:column;position:relative}</style></head><body>\n    <div class='stamp'>Launch · Week 4</div>\n    <div class='ghost' style='color:rgba(15,43,70,0.08)'>5</div>\n    <div class='micro' style='background:rgba(244,195,23,0.35);color:#0f2b46'>Gate 5 · Trust Tier</div>\n    <div style='margin-top:32px;position:relative;z-index:1'>\n      <div style='font-weight:700;font-size:64px;line-height:1.02;letter-spacing:-0.015em'>Higher-tier agents<br/>earn more weight<br/>on the dataset.</div>\n      <div style='font-weight:500;font-size:24pt;line-height:1.35;margin-top:24px;color:rgba(15,43,70,0.82);max-width:900px'>Because they've earned it. The point lands on the map only after all five gates clear.</div>\n    </div>\n    <div style='margin-top:32px;display:flex;gap:14px;flex-wrap:wrap;position:relative;z-index:1'>\n      <div style='padding:14px 22px;border-radius:14px;background:rgba(15,43,70,0.12);font-weight:700;font-size:16pt'>Bronze</div>\n      <div style='padding:14px 22px;border-radius:14px;background:rgba(15,43,70,0.18);font-weight:700;font-size:16pt'>Silver</div>\n      <div style='padding:14px 22px;border-radius:14px;background:#0f2b46;color:#f4c317;font-weight:700;font-size:16pt'>Gold</div>\n    </div>\n    <div style='margin-top:auto;display:flex;flex-direction:column;gap:16px;position:relative;z-index:1'>\n      <div style='align-self:flex-start;padding:22px 34px;border-radius:999px;background:#0f2b46;color:#f2f6fa;font-weight:700;font-size:22pt;display:flex;align-items:center;gap:14px'>\n        <span>Download · DM \"MAP\" or \"CARTE\"</span>\n        <span style='color:#f4c317'>→</span>\n      </div>\n      <div style='font-weight:500;font-size:19pt;color:rgba(15,43,70,0.72)'>That's what we mean by ground truth.</div>\n    </div>\n  </body></html>"
  }
]