  {
    "id": "01-fr",
    "html": "<!doctype html><html><head><meta charset='utf-8'><link rel='preconnect' href='https://fonts.googleapis.com'><link rel='preconnect' href='https://fonts.gstatic.com' crossorigin><link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap' rel='stylesheet'><style>\nhtml,body{margin:0;padding:0;width:1080px;height:1350px;overflow:hidden;font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}\n*{box-sizing:border-box}\n.stamp{position:absolute;top:56px;right:56px;padding:14px 24px;border-radius:999px;background:#f4c317;border:2px solid #0f2b46;color:#0f2b46;font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;z-index:2}\n.micro{font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;padding:10px 20px;border-radius:999px;display:inline-block;align-self:flex-start}\n.accent-bar{height:6px;width:96px;border-radius:3px;margin:20px 0}\n.page-num{position:absolute;bottom:56px;right:72px;font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;opacity:0.55}\n.icon-chip{width:112px;height:112px;border-radius:32px;display:flex;align-items:center;justify-content:center}\n.icon-chip svg{width:60px;height:60px;stroke-width:2.4;fill:none;stroke-linecap:round;stroke-linejoin:round}\n.timestamp{font-weight:700;font-size:128px;line-height:0.85;letter-spacing:-0.04em;font-variant-numeric:tabular-nums}\nbody{background:#0f2b46;color:#f2f6fa;padding:80px;display:flex;flex-direction:column;position:relative}</style></head><body>\n    <div class='stamp'>Beta · Semaine 3</div>\n    <div class='micro' style='background:rgba(244,195,23,0.14);color:#f4c317'>Donnee Terrain · Travail de Quartier</div>\n    <div style='display:flex;align-items:center;gap:48px;margin-top:72px'>\n      <div style='font-weight:700;font-size:240px;line-height:0.85;letter-spacing:-0.04em;color:#c86b4a'>01</div>\n      <div style='display:flex;flex-direction:column;gap:14px'>\n        <div style='font-weight:700;font-size:22pt;letter-spacing:0.12em;text-transform:uppercase;color:rgba(242,246,250,0.75)'>Une matinee<br/>avec ADL</div>\n        <div style='width:64px;height:4px;background:#f4c317;border-radius:2px'></div>\n        <div style='font-weight:500;font-size:18pt;color:rgba(242,246,250,0.7)'>Beta — Douala</div>\n      </div>\n    </div>\n    <div style='margin-top:96px'>\n      <div style='font-weight:700;font-size:88px;line-height:1.02;letter-spacing:-0.015em'>Une matinee<br/>avec un agent<br/>ADL.</div>\n      <div style='font-weight:500;font-size:26pt;line-height:1.35;color:rgba(242,246,250,0.72);margin-top:28px;max-width:880px'>Cinq slides. Trois horaires. Une vraie tournee a Bonamoussadi — et ce que paie le travail.</div>\n    </div>\n    <div style='margin-top:auto;display:flex;align-items:center;gap:18px;font-weight:500;font-size:20pt;color:rgba(242,246,250,0.65)'>\n      <div style='width:32px;height:2px;background:#c86b4a'></div>\n      Glissez →\n    </div>\n  </body></html>"
  },
  {
    "id": "02-fr",
    "html": "<!doctype html><html><head><meta charset='utf-8'><link rel='preconnect' href='https://fonts.googleapis.com'><link rel='preconnect' href='https://fonts.gstatic.com' crossorigin><link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap' rel='stylesheet'><style>\nhtml,body{margin:0;padding:0;width:1080px;height:1350px;overflow:hidden;font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}\n*{box-sizing:border-box}\n.stamp{position:absolute;top:56px;right:56px;padding:14px 24px;border-radius:999px;background:#f4c317;border:2px solid #0f2b46;color:#0f2b46;font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;z-index:2}\n.micro{font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;padding:10px 20px;border-radius:999px;display:inline-block;align-self:flex-start}\n.accent-bar{height:6px;width:96px;border-radius:3px;margin:20px 0}\n.page-num{position:absolute;bottom:56px;right:72px;font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;opacity:0.55}\n.icon-chip{width:112px;height:112px;border-radius:32px;display:flex;align-items:center;justify-content:center}\n.icon-chip svg{width:60px;height:60px;stroke-width:2.4;fill:none;stroke-linecap:round;stroke-linejoin:round}\n.timestamp{font-weight:700;font-size:128px;line-height:0.85;letter-spacing:-0.04em;font-variant-numeric:tabular-nums}\nbody{background:#f2f6fa;color:#0f2b46;padding:80px;display:flex;flex-direction:column;position:relative}</style></head><body>\n    <div class='stamp'>Beta · Semaine 3</div>\n    <div class='micro' style='background:rgba(200,107,74,0.14);color:#c86b4a'>La Tournee</div>\n    <div class='icon-chip' style='background:#fff8f4;margin-top:40px'>\n      <svg viewBox='0 0 24 24' stroke='#c86b4a'><circle cx='12' cy='12' r='3'/><path d='M12 2v4M12 18v4M2 12h4M18 12h4'/></svg>\n    </div>\n    <div class='timestamp' style='color:#c86b4a;margin-top:32px'>08:14</div>\n    <div style='font-weight:700;font-size:64px;line-height:1.04;letter-spacing:-0.01em;margin-top:24px'>A pied dans<br/>Bonamoussadi.</div>\n    <div style='font-weight:500;font-size:26pt;line-height:1.35;color:rgba(15,43,70,0.78);margin-top:24px;max-width:920px'>Trois arrets sur la tournee : une pharmacie, une station-service, un kiosque mobile money.</div>\n    <div style='display:flex;gap:14px;margin-top:32px;flex-wrap:wrap'>\n      <div style='padding:12px 20px;border-radius:14px;background:#0f2b46;color:#f2f6fa;font-weight:600;font-size:16pt'>Pharmacie</div>\n      <div style='padding:12px 20px;border-radius:14px;background:#c86b4a;color:#fff8f4;font-weight:600;font-size:16pt'>Station-service</div>\n      <div style='padding:12px 20px;border-radius:14px;background:#f4c317;color:#0f2b46;font-weight:600;font-size:16pt'>Mobile money</div>\n    </div>\n    <div style='margin-top:auto;font-weight:500;font-style:italic;font-size:22pt;color:rgba(15,43,70,0.6)'>« Pas de mallette. Pas de siege social. Juste le quartier. »</div>\n    <div class='page-num' style='color:#0f2b46'>02 / 05</div>\n  </body></html>"
  },
  {
    "id": "03-fr",
    "html": "<!doctype html><html><head><meta charset='utf-8'><link rel='preconnect' href='https://fonts.googleapis.com'><link rel='preconnect' href='https://fonts.gstatic.com' crossorigin><link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap' rel='stylesheet'><style>\nhtml,body{margin:0;padding:0;width:1080px;height:1350px;overflow:hidden;font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}\n*{box-sizing:border-box}\n.stamp{position:absolute;top:56px;right:56px;padding:14px 24px;border-radius:999px;background:#f4c317;border:2px solid #0f2b46;color:#0f2b46;font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;z-index:2}\n.micro{font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;padding:10px 20px;border-radius:999px;display:inline-block;align-self:flex-start}\n.accent-bar{height:6px;width:96px;border-radius:3px;margin:20px 0}\n.page-num{position:absolute;bottom:56px;right:72px;font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;opacity:0.55}\n.icon-chip{width:112px;height:112px;border-radius:32px;display:flex;align-items:center;justify-content:center}\n.icon-chip svg{width:60px;height:60px;stroke-width:2.4;fill:none;stroke-linecap:round;stroke-linejoin:round}\n.timestamp{font-weight:700;font-size:128px;line-height:0.85;letter-spacing:-0.04em;font-variant-numeric:tabular-nums}\nbody{background:#eaf1ec;color:#0f2b46;padding:80px;display:flex;flex-direction:column;position:relative}</style></head><body>\n    <div class='stamp'>Beta · Semaine 3</div>\n    <div class='micro' style='background:rgba(76,124,89,0.18);color:#2f5438'>La Capture</div>\n    <div class='accent-bar' style='background:#4c7c59'></div>\n    <div class='timestamp' style='color:#4c7c59;margin-top:8px'>09:02</div>\n    <div style='font-weight:700;font-size:64px;line-height:1.04;letter-spacing:-0.01em;margin-top:24px'>Premiere capture.</div>\n    <div style='font-weight:500;font-size:26pt;line-height:1.35;margin-top:24px;max-width:920px'>Le GPS verrouille. La camera declenche. L'EXIF horodate. La file hors-ligne garde tout si le reseau coupe.</div>\n    <div style='display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:36px;max-width:920px'>\n      <div style='padding:24px;border-radius:20px;background:#ffffff;border:2px solid rgba(76,124,89,0.25)'>\n        <div style='font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;color:#4c7c59'>Verrou GPS</div>\n        <div style='font-weight:700;font-size:22pt;margin-top:8px;line-height:1.2'>Dans la zone</div>\n      </div>\n      <div style='padding:24px;border-radius:20px;background:#ffffff;border:2px solid rgba(76,124,89,0.25)'>\n        <div style='font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;color:#4c7c59'>Photo + EXIF</div>\n        <div style='font-weight:700;font-size:22pt;margin-top:8px;line-height:1.2'>Heure · Appareil</div>\n      </div>\n      <div style='padding:24px;border-radius:20px;background:#ffffff;border:2px solid rgba(76,124,89,0.25)'>\n        <div style='font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;color:#4c7c59'>File hors-ligne</div>\n        <div style='font-weight:700;font-size:22pt;margin-top:8px;line-height:1.2'>Tient en 2G</div>\n      </div>\n      <div style='padding:24px;border-radius:20px;background:#ffffff;border:2px solid rgba(76,124,89,0.25)'>\n        <div style='font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;color:#4c7c59'>Sync auto</div>\n        <div style='font-weight:700;font-size:22pt;margin-top:8px;line-height:1.2'>Au retour reseau</div>\n      </div>\n    </div>\n    <div style='margin-top:auto;font-weight:500;font-style:italic;font-size:22pt;color:rgba(15,43,70,0.65)'>« Le mauvais reseau n'est plus votre probleme. »</div>\n    <div class='page-num' style='color:#0f2b46'>03 / 05</div>\n  </body></html>"
  },
  {
    "id": "04-fr",
    "html": "<!doctype html><html><head><meta charset='utf-8'><link rel='preconnect' href='https://fonts.googleapis.com'><link rel='preconnect' href='https://fonts.gstatic.com' crossorigin><link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap' rel='stylesheet'><style>\nhtml,body{margin:0;padding:0;width:1080px;height:1350px;overflow:hidden;font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}\n*{box-sizing:border-box}\n.stamp{position:absolute;top:56px;right:56px;padding:14px 24px;border-radius:999px;background:#f4c317;border:2px solid #0f2b46;color:#0f2b46;font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;z-index:2}\n.micro{font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;padding:10px 20px;border-radius:999px;display:inline-block;align-self:flex-start}\n.accent-bar{height:6px;width:96px;border-radius:3px;margin:20px 0}\n.page-num{position:absolute;bottom:56px;right:72px;font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;opacity:0.55}\n.icon-chip{width:112px;height:112px;border-radius:32px;display:flex;align-items:center;justify-content:center}\n.icon-chip svg{width:60px;height:60px;stroke-width:2.4;fill:none;stroke-linecap:round;stroke-linejoin:round}\n.timestamp{font-weight:700;font-size:128px;line-height:0.85;letter-spacing:-0.04em;font-variant-numeric:tabular-nums}\nbody{background:#f2f6fa;color:#0f2b46;padding:80px;display:flex;flex-direction:column;position:relative}</style></head><body>\n    <div class='stamp'>Beta · Semaine 3</div>\n    <div class='micro' style='background:rgba(244,195,23,0.28);color:#0f2b46'>Le Resultat</div>\n    <div class='accent-bar' style='background:#f4c317'></div>\n    <div class='timestamp' style='color:#c86b4a;margin-top:8px'>11:30</div>\n    <div style='font-weight:700;font-size:64px;line-height:1.04;letter-spacing:-0.01em;margin-top:24px'>Le score de<br/>confiance monte.</div>\n    <div style='font-weight:500;font-size:26pt;line-height:1.35;color:rgba(15,43,70,0.78);margin-top:24px;max-width:920px'>Trois points passent la revue avant midi. La serie tient. Les XP s'accumulent. Un travail verifie, reconnu vite.</div>\n    <div style='margin-top:40px;padding:32px;border-radius:24px;background:#0f2b46;color:#f2f6fa;max-width:940px'>\n      <div style='font-weight:700;font-size:15pt;letter-spacing:0.08em;text-transform:uppercase;color:#f4c317'>Le pipeline ADL</div>\n      <div style='font-weight:600;font-size:24pt;line-height:1.3;margin-top:12px'>GPS + EXIF + score de risque + niveau de confiance — chaque soumission est auditee avant d'apparaitre sur la carte publique.</div>\n    </div>\n    <div style='margin-top:auto;font-weight:500;font-style:italic;font-size:22pt;color:rgba(15,43,70,0.65)'>« Travail verifie, reconnu vite. »</div>\n    <div class='page-num' style='color:#0f2b46'>04 / 05</div>\n  </body></html>"
  },
  {
    "id": "05-fr",
    "html": "<!doctype html><html><head><meta charset='utf-8'><link rel='preconnect' href='https://fonts.googleapis.com'><link rel='preconnect' href='https://fonts.gstatic.com' crossorigin><link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap' rel='stylesheet'><style>\nhtml,body{margin:0;padding:0;width:1080px;height:1350px;overflow:hidden;font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}\n*{box-sizing:border-box}\n.stamp{position:absolute;top:56px;right:56px;padding:14px 24px;border-radius:999px;background:#f4c317;border:2px solid #0f2b46;color:#0f2b46;font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;z-index:2}\n.micro{font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;padding:10px 20px;border-radius:999px;display:inline-block;align-self:flex-start}\n.accent-bar{height:6px;width:96px;border-radius:3px;margin:20px 0}\n.page-num{position:absolute;bottom:56px;right:72px;font-weight:700;font-size:13pt;letter-spacing:0.1em;text-transform:uppercase;opacity:0.55}\n.icon-chip{width:112px;height:112px;border-radius:32px;display:flex;align-items:center;justify-content:center}\n.icon-chip svg{width:60px;height:60px;stroke-width:2.4;fill:none;stroke-linecap:round;stroke-linejoin:round}\n.timestamp{font-weight:700;font-size:128px;line-height:0.85;letter-spacing:-0.04em;font-variant-numeric:tabular-nums}\nbody{background:#c86b4a;color:#0f2b46;padding:80px;display:flex;flex-direction:column;position:relative}</style></head><body>\n    <div class='stamp'>Beta · Semaine 3</div>\n    <div class='micro' style='background:rgba(244,195,23,0.35);color:#0f2b46'>Beta · Postulez</div>\n    <div style='margin-top:56px'>\n      <div style='font-weight:700;font-size:80px;line-height:1.02;letter-spacing:-0.015em'>Travail de<br/>terrain — paye<br/>en vraies<br/>recompenses.</div>\n      <div style='font-weight:500;font-size:26pt;line-height:1.35;margin-top:28px;color:rgba(15,43,70,0.82);max-width:900px'>Beta ouverte pour les agents de terrain a Douala. Si vous connaissez votre quartier — postulez cette semaine.</div>\n    </div>\n    <div style='margin-top:40px;display:grid;grid-template-columns:1fr 1fr;gap:16px;max-width:900px'>\n      <div style='padding:22px 26px;border-radius:20px;background:rgba(15,43,70,0.08);border:2px solid rgba(15,43,70,0.18)'>\n        <div style='font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;opacity:0.7'>Mot-cle FR</div>\n        <div style='font-weight:700;font-size:24pt;margin-top:6px;line-height:1.2'>DM « TERRAIN »</div>\n      </div>\n      <div style='padding:22px 26px;border-radius:20px;background:rgba(15,43,70,0.08);border:2px solid rgba(15,43,70,0.18)'>\n        <div style='font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;opacity:0.7'>Mot-cle EN</div>\n        <div style='font-weight:700;font-size:24pt;margin-top:6px;line-height:1.2'>DM \"AGENT\"</div>\n      </div>\n    </div>\n    <div style='margin-top:auto;display:flex;flex-direction:column;gap:16px'>\n      <div style='align-self:flex-start;padding:22px 34px;border-radius:999px;background:#0f2b46;color:#f2f6fa;font-weight:700;font-size:22pt;display:flex;align-items:center;gap:14px'>\n        <span>Postulez cette semaine</span>\n        <span style='color:#f4c317'>→</span>\n      </div>\n      <div style='font-weight:500;font-size:19pt;color:rgba(15,43,70,0.72)'>On repond dans la semaine. Enregistrez. Partagez avec un proche a Douala.</div>\n    </div>\n  </body></html>"
  }
]