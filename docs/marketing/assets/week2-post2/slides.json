    "id": "01",
    "html": "<!doctype html><html><head><meta charset='utf-8'><link rel='preconnect' href='https://fonts.googleapis.com'><link rel='preconnect' href='https://fonts.gstatic.com' crossorigin><link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap' rel='stylesheet'><style>html,body{margin:0;padding:0;width:1080px;height:1350px;overflow:hidden;font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}body{background:#0f2b46;color:#f2f6fa;position:relative;padding:80px;box-sizing:border-box;display:flex;flex-direction:column;justify-content:space-between}.label{font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;color:#f4c317;padding:8px 16px;border-radius:999px;background:rgba(244,195,23,0.1);display:inline-block;align-self:flex-start}.headline{font-weight:700;font-size:72px;line-height:1.05;letter-spacing:-0.01em;max-width:900px}.stamp{position:absolute;top:80px;right:80px;width:128px;height:128px;border-radius:50%;background:#f4c317;color:#0f2b46;font-weight:700;font-size:16pt;letter-spacing:0.06em;display:flex;align-items:center;justify-content:center;transform:rotate(-8deg);text-align:center}.corner{position:absolute;bottom:0;left:0;width:240px;height:240px;background:#c86b4a;opacity:0.6;border-top-right-radius:240px}.footer{font-weight:500;font-size:22pt;color:rgba(242,246,250,0.7)}</style></head><body><div class='label'>GROUND TRUTH · 01/05</div><div class='stamp'>ADL<br>VERIFIED</div><div class='headline'>Verified isn't a label.<br>It's a pipeline.</div><div class='footer'>Swipe →</div><div class='corner'></div></body></html>"
  },
  {
    "id": "02",
    "html": "<!doctype html><html><head><meta charset='utf-8'><link rel='preconnect' href='https://fonts.googleapis.com'><link rel='preconnect' href='https://fonts.gstatic.com' crossorigin><link href='https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap' rel='stylesheet'><style>html,body{margin:0;padding:0;width:1080px;height:1350px;overflow:hidden;font-family:'Inter',system-ui,sans-serif;-webkit-font-smoothing:antialiased}body{background:#f2f6fa;color:#0f2b46;padding:80px;box-sizing:border-box;display:flex;flex-direction:column;gap:32px}.label{font-weight:700;font-size:14pt;letter-spacing:0.08em;text-transform:uppercase;color:#c86b4a;padding:8px 16px;border-radius:999px;background:rgba(200,107,74,0.1);display:inline-block;align-self:flex-start}.bubble{width:128px;height:128px;border-radius:50%;background:#fff8f4;display:flex;align-items:center;justify-content:center;margin-top:40px}.bubble svg{width:64px;height:64px;stroke:#c86b4a;stroke-width:2.5;fill:none;stroke-linecap:round;stroke-linejoin:round}.headline{font-weight:700;font-size:60px;line-height:1.05;letter-spacing:-0.01em;margin-top:40px}.body{font-weight:500;font-size:28pt;line-height:1.3;margin-top:16px;max-width:900px}.detail{font-weight:400;font-style:italic;font-size:22pt;color:rgba(15,43,70,0.7);margin-top:auto}</style></head><body><div class='label'>STEP 01 · GPS LOCK</div><div class='bubble'><svg viewBox='0 0 24 24'><circle cx='12' cy='10' r='3'/><path d='M12 2a8 8 0 0 0-8 8c0 5.5 8 12 8 12s8-6.5 8-12a8 8 0 0 0-8-8z'/></svg></div><div class='headline'>Inside pilot geofence.</div><div class='body'>Velocity checked against prior submissions. Coordinates rounded for privacy.</div><div class='detail'>\"No teleporting agents.\"</div></body></html>"
