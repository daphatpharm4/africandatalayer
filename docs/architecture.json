  "data_model": {
    "primary_db": "PostgreSQL via Supabase",
    "tables_inferred_from_migrations": [
      "users (auth, trust, roles)",
      "submissions (event log)",
      "projected_points (merged points)",
      "snapshots (weekly/monthly deltas)",
      "collection_zones, collection_assignments",
      "verticals (active categories)",
      "fraud_alerts, security_audit, ip_reports",
      "admin_account_creation_audit",
      "policy_acceptance",
      "automation_lead_queue",
      "email_campaigns, email_templates, email_unsubscribe",
      "sms_campaigns, sms_consent_log",
      "password_reset_tokens",
      "poi_candidates"
    ],
    "client_storage": {
      "indexeddb": "adl_offline_queue (75 items max, 6 retries, 72h TTL)",
      "localstorage": "language, splash flag, auth flag",
      "session_cookies": "auth.js session token"
    }
  },
  "external_services": [
    { "name": "Vercel",            "use": "hosting, cron, blob, edge-config" },
    { "name": "Supabase Postgres", "use": "primary db (pg driver, no ORM)" },
    { "name": "Sentry",            "use": "error tracking (browser + node)" },
    { "name": "Google OAuth",      "use": "social login via @auth/core" },
